# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plano_cv

# YOLO
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.20

# Embedding matching
REFERENCE_MATCH_THRESHOLD=0.55
SIMILARITY_THRESHOLD=0.60

# Hungarian full-shelf matching weights
MATCH_ALPHA=0.7
MATCH_BETA=0.3

# Storage (local disk for this minimal build, no MinIO yet)
UPLOAD_DIR=./uploads
